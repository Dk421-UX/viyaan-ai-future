generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String
  createdAt DateTime @default(now())
  entries   Entry[]
}

model Entry {
  id              String   @id @default(uuid())
  userId          String
  inputText       String
  generatedText   String
  intensityBefore Int
  intensityAfter  Int?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}